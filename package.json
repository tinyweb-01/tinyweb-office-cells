{
  "name": "tinyweb-office-cells",
  "version": "1.1.2",
  "description": "Open-source Node.js/TypeScript library for reading, writing, and manipulating Excel XLSX files with full formatting, formula evaluation, and Aspose Cells-compatible API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "version:patch": "npm version patch -m 'chore: release v%s'",
    "version:minor": "npm version minor -m 'chore: release v%s'",
    "version:major": "npm version major -m 'chore: release v%s'",
    "release": "npm run build && npm test && npm publish --provenance --access public"
  },
  "keywords": [
    "excel",
    "xlsx",
    "spreadsheet",
    "aspose",
    "cells",
    "typescript",
    "formula",
    "workbook",
    "worksheet",
    "formatting",
    "data-validation",
    "conditional-formatting",
    "hyperlinks",
    "named-ranges",
    "autofilter",
    "node"
  ],
  "license": "MIT",
  "author": "tinyweb-office-cells contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyweb-01/tinyweb-office-cells.git"
  },
  "homepage": "https://github.com/tinyweb-01/tinyweb-office-cells#readme",
  "bugs": {
    "url": "https://github.com/tinyweb-01/tinyweb-office-cells/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.2",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.41.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "puppeteer": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    }
  }
}
